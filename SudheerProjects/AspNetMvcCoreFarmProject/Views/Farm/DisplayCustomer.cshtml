@model Customer
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Customer Details</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            background: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .thumbnail-click {
            max-width: 120px;
            height: auto;
            object-fit: cover;
            border-radius: 0.5rem;
            cursor: pointer;
        }

        .card-header {
            background: #198754;
            color: #fff;
            font-weight: 600;
            letter-spacing: 0.03em;
        }

        table th {
            background-color: #e9f5ec;
            font-weight: 600;
            vertical-align: middle;
            width: 20%;
            white-space: nowrap;
        }

        table td {
            vertical-align: middle;
        }
        /* Smaller thumbnails for images */
        img.thumbnail-click {
            cursor: pointer;
            border-radius: 0.5rem;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
            width: 100%;
            height: 140px;
            object-fit: cover;
            box-shadow: 0 0 6px rgba(0, 0, 0, 0.1);
        }

            img.thumbnail-click:hover,
            img.thumbnail-click:focus {
                transform: scale(1.08);
                box-shadow: 0 0 12px rgba(25, 135, 84, 0.6);
                z-index: 1;
                position: relative;
            }
        /* Modal image styles */
        .modal-img {
            max-height: 80vh;
            object-fit: contain;
            margin: 0 auto;
            /* user-select: none;
            pointer-events: none; */
        }
        /* Carousel controls more visible */
        .carousel-control-prev-icon,
        .carousel-control-next-icon {
            filter: invert(1);
            opacity: 0.85;
            width: 2.5rem;
            height: 2.5rem;
        }
        /* Responsive tweaks */
        @@media (max-width: 576px) {
            img .thumbnail-click

        {
            height: 110px;
        }

        table th,
        table td {
            font-size: 0.9rem;
            padding: 0.5rem 0.6rem;
        }

        }
        @@media (max-width: 400px) {
            img .thumbnail-click

        {
            height: 90px;
        }

        }
    </style>
</head>
<body>
    <div class="container py-4">
        <div class="card shadow-sm">
            <div class="card-header text-center">
                <h4 class="mb-0">Customer Details</h4>
            </div>
            <div class="card-body p-4">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-3">
                        <tbody>
                            <tr>
                                <th>Farmer Name</th>
                                <td>@Model.Name</td>
                            </tr>
                            <tr>
                                <th>Mobile Number</th>
                                <td>@Model.Identity_Phone</td>
                            </tr>
                            <tr>
                                <th>First Breed</th>
                                <td>@Model.FirstBreed</td>
                                <td><strong>@Model.FB_Price</strong> RS (Price per piece)</td>
                                <td><strong>@Model.FB_Pieces</strong> PCS (Available pieces)</td>
                            </tr>
                            <tr>
                                <th>Second Breed</th>
                                <td>@Model.SecondBreed</td>
                                @if (Model.SecondBreed == "---")
                                {
                                    <td><strong>@Model.SB_Price</strong></td>
                                    <td><strong>@Model.SB_Pieces</strong></td>
                                }
                                else
                                {
                                    <td><strong>@Model.SB_Price</strong> RS (Price per piece)</td>
                                    <td><strong>@Model.SB_Pieces</strong> PCS (Available pieces)</td>
                                }
                            </tr>
                            <tr>
                                <th>Third Breed</th>
                                <td>@Model.ThirdBreed</td>
                                <td><strong>@Model.TB_Price</strong> RS (Price per piece)</td>
                                <td><strong>@Model.TB_Pieces</strong> PCS (Available pieces)</td>
                            </tr>
                            <tr>
                                <th>Farmer Address</th>
                                <td colspan="3">@Model.Address</td>
                            </tr>
                            <tr>
                                <th>Images</th>
                                <td colspan="3">
                                    <div class="row g-2">
                                        @for (int i = 0; i < Model.ImagePath.Count; i++)
                                        {
                                            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                                                <img src="@Url.Content("~/images/" + Model.ImagePath[i])"
                                                     class="thumbnail-click"
                                                     data-bs-toggle="modal"
                                                     data-bs-target="#imageModal"
                                                     data-index="@i"
                                                     alt="Customer Image @(i + 1)" />
                                            </div>
                                        }
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                    <div class="text-center mt-3">
                        <button type="button" onclick="history.back()" class="btn btn-outline-success px-4">
                            &larr; Back
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal with Carousel -->
    <div class="modal fade" id="imageModal" tabindex="-1" aria-labelledby="imageModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-fullscreen-sm-down modal-dialog-centered">
            <div class="modal-content bg-dark">
                <div class="modal-header border-0">
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0">
                    <div id="carouselImages" class="carousel slide" data-bs-ride="false">
                        <div class="carousel-inner">
                            @for (int i = 0; i < Model.ImagePath.Count; i++)
                            {
                                var imgUrl = Url.Content("~/images/" + Model.ImagePath[i]);
                                <div class="carousel-item @(i == 0 ? "active" : "")">
                                    <img src="@imgUrl" class="modal-img img-fluid rounded" alt="Image @(i + 1)" />
                                </div>
                            }
                        </div>
                        <button class="carousel-control-prev" type="button" data-bs-target="#carouselImages" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon"></span>
                            <span class="visually-hidden">Previous</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#carouselImages" data-bs-slide="next">
                            <span class="carousel-control-next-icon"></span>
                            <span class="visually-hidden">Next</span>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('imageModal');
            const carousel = document.getElementById('carouselImages');

            modal.addEventListener('show.bs.modal', event => {
                const trigger = event.relatedTarget;
                const index = parseInt(trigger.getAttribute('data-index'), 10);
                let carouselInstance = bootstrap.Carousel.getInstance(carousel);
                if (!carouselInstance) {
                    carouselInstance = new bootstrap.Carousel(carousel, { ride: false });
                }
                carouselInstance.to(index);
            });
        });
    </script>
</body>
</html>
