
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>EmpForm1</title>
</head>
<body>
    <div>
        <table border="1" align="center">
            <caption>Employee Details: </caption>
            <tr style="color:red;background-color:yellow"><td>Employee ID:</td><td>@ViewBag.id</td></tr>
            <tr><td>Employee Name:</td><td>@ViewBag.name</td></tr>
            <tr><td>Employee Job:</td><td>@ViewBag.job</td></tr>
            <tr><td>Employee Salary:</td><td>@ViewBag.salary</td></tr>

            <tr>
                <td colspan="2" align="center"><a href="/Home/AddEmp">Add a new Employee</a></td>
            </tr>
        </table>
    </div>
</body>
</html>
