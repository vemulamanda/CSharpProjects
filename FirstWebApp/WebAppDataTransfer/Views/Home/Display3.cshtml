
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Display3</title>
</head>
<body>
    <div>

        @{
            HttpCookie cookie = Request.Cookies["Product Cookie"];
            int? id = int.Parse(cookie["id"]);
            string item = cookie["item"];.
            double? price = double.Parse(cookie["price"]);
        }

        <table align="center" border="1" style:."width="50%">
            <caption>Product Details</caption>
            <tr>
                <td>ID :</td>
                <td>@id</td>
            </tr>
            <tr>
                <td>ID :</td>
                <td>@item</td>
            </tr>
            <tr>
                <td>ID :</td>
                <td>
                    @{
                        price = price + (price * 0.1);
                        @price
                    }
                </td>
            </tr>
        </table>
        <center>
            Click to lauch page <a href="/Test/Index2">click here</a>
        </center>
    </div>
</body>
</html>
