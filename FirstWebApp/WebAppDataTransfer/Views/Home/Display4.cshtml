
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Display4</title>
</head>
<body>
    <div>
        <table align="center" border="1" style="width=" 50%">
            <caption>Product Details</caption>
            <tr>
                <td>ID :</td>
                <td>@Session["id"]</td>
            </tr>
            <tr>
                <td>ID :</td>
                <td>@Session["item"]</td>
            </tr>
            <tr>
                <td>ID :</td>
                <td>
                    @{
                        double price = Convert.ToDouble(Session["price"]);
                        price = price + (price * 0.1);
                        @price
                    }
                </td>
            </tr>
        </table>
    </div>
</body>
</html>
