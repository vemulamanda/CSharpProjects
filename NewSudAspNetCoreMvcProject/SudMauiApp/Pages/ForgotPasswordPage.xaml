<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SudMauiApp.Pages.ForgotPasswordPage">
    
    <Border Margin="10">
    <VerticalStackLayout>
        <Border Margin="20" Padding="10,20,20,20" BackgroundColor="Black" StrokeThickness="3" StrokeShape="17">
            <Label 
                Text="Reset Password"
                FontSize="Large"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Center" 
                HorizontalOptions="Center" />
        </Border>

        <Label Text="Enter your registered email address"
               TextColor="Green"
               FontAttributes="Bold"
               FontSize="20"
               Margin="20,40,0,0"/>

        <Label Text="Email"
               TextColor="Red"
               FontSize="Large"
               FontAttributes="Bold"
               FontFamily="Alebrijes"
               Margin="20,40,0,10"/>

        <Border StrokeThickness="1" StrokeShape="5" Padding="0,0,0,5" Margin="10,0,10,30" BackgroundColor="White">
            <Entry x:Name="emailentry"
                   Placeholder="Enter Email Address"
                   PlaceholderColor="Gray"
                   TextColor="Black"
                   FontSize="20" Margin="10,7,0,3"
                   ClearButtonVisibility="WhileEditing"/>
        </Border>

        <Button x:Name="btn_ResetPassword"
                Text="Submit"
                Clicked="btn_ResetPassword_Clicked"
                FontSize="23" Margin="90,0,90,0"
                TextColor="White"
                FontAttributes="Bold"
                BackgroundColor="Black"/>

        <Grid x:Name="LoadingOverlay"
              BackgroundColor="White"
              IsVisible="False"
              VerticalOptions="FillAndExpand"
              HorizontalOptions="FillAndExpand">            
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                <ActivityIndicator IsRunning="True" Color="Green"/>
                <Label Text="Loading..." TextColor="White" FontSize="Large" />
            </VerticalStackLayout>
        </Grid>
        
    </VerticalStackLayout>
    </Border>
</ContentPage>