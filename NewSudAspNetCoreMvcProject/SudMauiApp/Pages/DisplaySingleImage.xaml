<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SudMauiApp.Pages.DisplaySingleImage"
             xmlns:pages="clr-namespace:SudMauiApp.Pages"
             Title="DisplaySingleImage">
    <VerticalStackLayout>
        <Image Source="{Binding}"
               Aspect="AspectFit"
               VerticalOptions="Center"
               HeightRequest="300"
               WidthRequest="300"/>
    </VerticalStackLayout>
</ContentPage>