<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SudMauiApp.Pages.LoginPage">

    <Border Margin="7" Padding="0,20,0,0">
        <VerticalStackLayout>
            <Border StrokeThickness="3" StrokeShape="10" Padding="0,5,0,-30" Margin="20,0,20,30" BackgroundColor="Green" >
                <Label Text="Login"
                       TextColor="White"
                       FontSize="25"
                       FontAttributes="Bold"
                       Padding="0,0,0,40"
                       VerticalOptions="Center" 
                       HorizontalOptions="Center" />
            </Border>

            <Border StrokeThickness="1" StrokeShape="5" Padding="0,0,0,5" Margin="10,0,10,30" BackgroundColor="White">
                <Entry x:Name="username"
                   Placeholder="Enter Username"
                   PlaceholderColor="Gray"
                   TextColor="Black"
                   FontSize="20" Margin="10,0,10,0"
                   ClearButtonVisibility="WhileEditing"
                   />
            </Border>

            <Border StrokeThickness="1" StrokeShape="5" Padding="0,0,0,5" Margin="10,0,10,30" BackgroundColor="White">
                <Entry x:Name="password"
                Placeholder="Enter Password"
                PlaceholderColor="Gray"
                TextColor="Black"
                FontSize="20" Margin="10,0,10,0"
                ClearButtonVisibility="WhileEditing"
                IsPassword="True"/>
            </Border>

            <!--<CheckBox IsChecked="true" 
                  HorizontalOptions="Start"
                  Margin="20,0,0,20"
                  />-->

            <HorizontalStackLayout>
                <Label Text="Not Registered: "
                   FontSize="Medium"
                   Margin="30,0,-5,0"
                   FontAttributes="Bold"/>

                <Button x:Name="btn_Register"
                    Clicked="btn_Register_Clicked"
                    Text="Click Here"
                    BackgroundColor="White"
                    TextColor="Green"
                    Margin="10,-10,0,30"
                    FontSize="Medium"
                    FontAttributes="Bold"/>

            </HorizontalStackLayout>

            <HorizontalStackLayout>
                <Label Text="Forgot Password: "
                FontSize="Medium"
                Margin="30,0,-5,0"
                FontAttributes="Bold"/>

                <Button x:Name="btn_ForgotPassword"
                Clicked="btn_ForgotPassword_Clicked"
                Text="Click Here"
                BackgroundColor="White"
                TextColor="Green"
                Margin="10,-10,0,30"
                FontSize="Medium"
                FontAttributes="Bold"/>

            </HorizontalStackLayout>

            <Grid x:Name="LoadingOverlay"
                  BackgroundColor="White"
                  IsVisible="False"
                  VerticalOptions="FillAndExpand"
                  HorizontalOptions="FillAndExpand">
                
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True" Color="Green"/>
                    <Label Text="Loading..." TextColor="White" FontSize="Large" />
                </VerticalStackLayout>
            </Grid>

            <Button Text="Login"
                    x:Name="btn_LoginLogoff"
                    Clicked="Btn_Submit_Clicked"
                    FontSize="23" Margin="90,0,90,0"
                    TextColor="White"
                    FontAttributes="Bold"
                    BackgroundColor="Black"/>

            <Button Text="Delete Account"
                    x:Name="btn_DeleteAccount"
                    Clicked="btn_DeleteAccount_Clicked"
                    FontSize="23" Margin="90,50,90,0"
                    TextColor="White"
                    FontAttributes="Bold"
                    BackgroundColor="Red"/>

        </VerticalStackLayout>
        
    </Border>

</ContentPage>