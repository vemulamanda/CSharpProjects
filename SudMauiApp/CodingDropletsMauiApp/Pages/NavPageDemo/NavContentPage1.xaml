<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodingDropletsMauiApp.Pages.NavPageDemo.NavContentPage1"
             Title="NavContentPage1">
    <Label 
        Style="{StaticResource Headline}"
        Text="Welcome to Page01"
        VerticalOptions="Center" 
        HorizontalOptions="Center"
        TextColor="red"
        FontSize="Large"
        FontAttributes="Italic"
        Margin="20"
        TextDecorations="Underline"/>

    <Button 
        x:Name="BtnNxt_NavContentpage01"
        Text="Go to Page02"
        VerticalOptions="End"
        HorizontalOptions="End"
        FontSize="Large"
        Margin="0,200, 20, 0"
        Clicked="BtnNxt_NavContentpage01_Clicked"
    />
</ContentPage>