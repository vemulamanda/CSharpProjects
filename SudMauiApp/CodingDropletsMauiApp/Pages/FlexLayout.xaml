<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodingDropletsMauiApp.Pages.FlexLayout"
             Title="FlexLayout">
    <FlexLayout Direction="Column">
        <!--<Button Text="FlexDemo01" FlexLayout.Grow="1" BackgroundColor="Green"/>
        <Button Text="FlexDemo02" FlexLayout.Basis="130" FlexLayout.Order="-1"/>-->
        <Label BackgroundColor="DarkGreen" TextColor="White" 
               Text="welcome to coding droplets" 
               FontSize="20" FontAttributes="Bold" HorizontalTextAlignment="Center"/>

        <FlexLayout FlexLayout.Grow="1" Direction="Row">
            <VerticalStackLayout BackgroundColor="DarkGrey" FlexLayout.Basis="50">
                
            </VerticalStackLayout>
            <VerticalStackLayout BackgroundColor="White" FlexLayout.Grow="1">
                <Label Text="This is content area"/>
            </VerticalStackLayout >
            <VerticalStackLayout BackgroundColor="DarkGrey" FlexLayout.Basis="50">

            </VerticalStackLayout>
        </FlexLayout>

        <Label BackgroundColor="DarkGreen" Text="Thank You" TextColor="White"
               HorizontalTextAlignment="Center" Padding="10" FontAttributes="Bold"/>
    </FlexLayout>
</ContentPage>