<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CodingDropletsMauiApp.Pages.AbsoluteLayoutDemo"
             Title="AbsoluteLayoutDemo">
    <ScrollView Orientation="Both">
    <AbsoluteLayout>
        <Button Text="Fixed"
                AbsoluteLayout.LayoutBounds="10,20,200,50"/>
        
        <Button Text="Height Proportional"
                AbsoluteLayout.LayoutFlags="HeightProportional"
                AbsoluteLayout.LayoutBounds="10,90,300,.2"/>
        
        <Button Text="Width Proportional"
                AbsoluteLayout.LayoutFlags="WidthProportional"
                AbsoluteLayout.LayoutBounds="10,260,.8,70"/>
        
        <Button Text="Size Proportional"
                AbsoluteLayout.LayoutFlags="SizeProportional"
                AbsoluteLayout.LayoutBounds="10,350,.6,.2"/>

            <Button Text="X Proportional" BackgroundColor="Orange"
            AbsoluteLayout.LayoutFlags="XProportional"
            AbsoluteLayout.LayoutBounds=".1,530,200,50"/>

            <Button Text="Y Proportional" BackgroundColor="Green"
            AbsoluteLayout.LayoutFlags="YProportional"
            AbsoluteLayout.LayoutBounds=".1,.8,200,50"/>

            <Button Text="All Proportional" BackgroundColor="Black"
                AbsoluteLayout.LayoutFlags="All"
                AbsoluteLayout.LayoutBounds=".2,.9,.7,.1"/>
        </AbsoluteLayout>
    </ScrollView>
</ContentPage>